# Production deployment overrides
# Set BIND_ADDR=0.0.0.0 when the app must be reachable from a Dockerized reverse proxy.
BIND_ADDR=127.0.0.1
TOODUE_PORT=8527
RUST_LOG=toodue=info,tower_http=info

# Google Calendar two-way sync (optional). Create an OAuth web client in
# Google Cloud Console with redirect URI <PUBLIC_URL>/api/google/callback.
PUBLIC_URL=https://app.toodue.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
